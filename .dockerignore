# Ignore everything by default
*

# Core Dockerfile needs: dataflow/ and core/
# CLI Dockerfile needs: core/, cli/, ee-stub/
!dataflow/
!dataflow/**
!core/
!core/**
!cli/
!cli/**
!ee/
!ee/**
!ee-stub/
!ee-stub/**

# Exclude test/dev artifacts within allowed directories
**/node_modules
dataflow/build
dataflow/docs/superpowers
dataflow/public/monaco-editor
dataflow/.env
core/tmp
cli/build
cli/.gocache
cli/whodb-cli
